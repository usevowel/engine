# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model Configuration
GROQ_MODEL=openai/gpt-oss-120b

# OpenAI-compatible local vLLM example
# LLM_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_API_KEY=EMPTY
# OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:8067/v1
# OPENAI_COMPATIBLE_MODEL=lfm2.5-1.2b-instruct

# Reasoning Effort Configuration (for Groq models that support it)
# Valid values: 'none', 'low', 'medium', 'high', 'default'
# Defaults for Groq (reasoning is fast enough, so enabled):
#   - GPT-OSS models: 'medium' (better reasoning quality)
#   - Qwen models: 'default' (enables reasoning)
#   - Other models: 'low' (if they support reasoning effort)
# For other providers, reasoning is disabled by default (lowest latency)
# Uncomment to override default:
# GROQ_REASONING_EFFORT=medium

# Deepgram STT/TTS Configuration
# Get your API key from: https://console.deepgram.com
# DEEPGRAM_API_KEY=your_deepgram_api_key_here
# STT_PROVIDER=deepgram
# TTS_PROVIDER=deepgram
# DEEPGRAM_STT_MODEL=nova-3
# DEEPGRAM_STT_LANGUAGE=en-US
# DEEPGRAM_STT_SAMPLE_RATE=16000
# DEEPGRAM_TTS_MODEL=aura-2-thalia-en
# DEEPGRAM_TTS_SAMPLE_RATE=24000
# DEEPGRAM_TTS_ENCODING=linear16

# xAI Grok STT/TTS (streaming + REST). Get a key from https://console.x.ai
# STT_PROVIDER=grok
# TTS_PROVIDER=grok
# GROK_API_KEY=your_xai_api_key_here
# GROK_STT_MODEL=whisper-large-v3-turbo
# GROK_STT_LANGUAGE=en-US
# GROK_STT_SAMPLE_RATE=16000
# GROK_TTS_VOICE=rex
# GROK_TTS_SAMPLE_RATE=24000

# OpenAI-compatible STT/TTS Configuration
# Echoline is one compatible local audio server, e.g. http://localhost:8000/v1
# STT_PROVIDER=openai-compatible
# TTS_PROVIDER=openai-compatible
# ECHOLINE_BASE_URL=http://localhost:8000/v1
# ECHOLINE_API_KEY=
# ECHOLINE_STT_MODEL=Systran/faster-whisper-tiny
# ECHOLINE_STT_LANGUAGE=en
# ECHOLINE_STT_SAMPLE_RATE=24000
# ECHOLINE_TTS_MODEL=onnx-community/Kokoro-82M-v1.0-ONNX
# ECHOLINE_TTS_VOICE=af_heart
# ECHOLINE_TTS_SAMPLE_RATE=24000
# ECHOLINE_TTS_RESPONSE_FORMAT=wav
# DEFAULT_VOICE=af_heart

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Secret (auto-generated)
# Generate a secure random string for production
JWT_SECRET=your_jwt_secret_here

# API Key for Token Issuance
# This key is required to generate ephemeral tokens
# Keep this secret and only share with authorized clients
API_KEY=your_api_key_here

# Optional: dump streaming STT input (Grok, Deepgram, AssemblyAI path only) as WAV
# under .audio-debug/ when using Bun. Disabled on Cloudflare Workers. Not used with
# Silero or client-side VAD. Uncomment:
# STT_AUDIO_DEBUG=1
# STT_AUDIO_DEBUG_DIR=.audio-debug
# Per-session formatted JSON: streaming STT WebSocket messages + whole-session Groq Whisper reference transcript (needs GROQ_API_KEY or LLM_PROVIDER=groq; same dir; does not require STT_AUDIO_DEBUG):
# STT_STREAM_EVENTS_DEBUG=1

# Voice Activity Detection (VAD)
VAD_PROVIDER=silero
VAD_ENABLED=true
VAD_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=550
VAD_SPEECH_PAD_MS=0
# SILERO_VAD_MODEL_PATH=./vendor/silero-vad/silero_vad.onnx

# VAD Provider Mode - Selects the ONNX Runtime backend
# - 'node' (default): Uses onnxruntime-node (Node.js/Bun, supports GPU)
# - 'wasm': Uses onnxruntime-web (WASM for Cloudflare Workers)
# VAD_PROVIDER_MODE=node

# LLM Model Parameters (defaults, can be overridden via token)
# Temperature (0.0-2.0, undefined = provider default)
# DEFAULT_TEMPERATURE=0.7
# Frequency penalty (0.0-2.0, helps reduce repetition by penalizing frequent tokens)
# DEFAULT_FREQUENCY_PENALTY=0.5
# Presence penalty (0.0-2.0, helps reduce repetition by penalizing tokens that appeared)
# DEFAULT_PRESENCE_PENALTY=0.3
# Repetition penalty (0.0-2.0, OpenRouter-specific, helps reduce repetition of tokens from input)
# DEFAULT_REPETITION_PENALTY=1.0

# Call Duration Limits
# Default maximum call duration in milliseconds (default: 30 minutes = 1800000ms)
MAX_CALL_DURATION_MS=1800000
# Default maximum idle duration in milliseconds (default: 10 minutes = 600000ms)
MAX_IDLE_DURATION_MS=600000

# Response Filter Configuration (AI-driven deduplication and translation)
# Enabled by default - set to "false" to disable
# RESPONSE_FILTER_ENABLED=true
# Filter mode: 'deduplication', 'translation', or 'both' (default: 'deduplication')
# RESPONSE_FILTER_MODE=deduplication
# Target language for translation (ISO 639-1 code, e.g., 'en', 'es', 'fr')
# RESPONSE_FILTER_TARGET_LANGUAGE=
# Filter LLM model (default: 'openai/gpt-oss-20b')
# RESPONSE_FILTER_MODEL=openai/gpt-oss-20b
# Buffer size in characters before filtering (default: 200)
# RESPONSE_FILTER_BUFFER_SIZE=200
# Maximum recent chunks for comparison (default: 10)
# RESPONSE_FILTER_MAX_RECENT_CHUNKS=10

# Cloudflare Tunnel (optional)
# Get your token from: https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
