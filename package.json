{
  "name": "@usevowel/engine",
  "version": "0.1.0",
  "description": "OpenAI-compatible real-time voice API server with modular providers",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:nodebug": "bun --no-env-file --env-file=.env --env-file=.dev.vars --watch packages/runtime-node/src/server.ts",
    "dev": "bun --inspect=ws://127.0.0.1:9229/engine --no-env-file --env-file=.env --env-file=.dev.vars --watch packages/runtime-node/src/server.ts",
    "build": "bun run --filter './packages/runtime-node' build",
    "build:packages": "bun run build",
    "start": "bun --no-env-file --env-file=.env --env-file=.dev.vars packages/runtime-node/src/server.ts",
    "postinstall": "bun run download-vad",
    "setup": "bun run scripts/setup.ts",
    "download-voice": "bun run scripts/download-voice.ts",
    "download-vad": "bun run scripts/download-vad.ts",
    "test:connection": "bun run test/connection-test.ts",
    "test:browser": "bun run test/browser-connection-test.ts",
    "test:playwright": "playwright test",
    "test:token": "bun run scripts/test-token-decoding.ts",
    "version": "bun run scripts/version.ts",
    "version:major": "bun run scripts/version.ts --type major",
    "version:minor": "bun run scripts/version.ts --type minor",
    "version:patch": "bun run scripts/version.ts --type patch",
    "version:check": "bun run scripts/version.ts --dry-run",
    "test": "bun test",
    "test:config": "bun test test/r2-config-loader.test.ts"
  },
  "dependencies": {
    "@ai-sdk/cerebras": "^1.0.31",
    "@ai-sdk/groq": "^3.0.33",
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/provider": "^3.0.8",
    "@aws-sdk/client-s3": "^3.987.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "ai": "^6.0.146",
    "franc": "^6.2.0",
    "fuzzball": "^2.2.3",
    "jose": "^5.2.0",
    "onnxruntime-web": "^1.24.3",
    "rxjs": "^7.8.2",
    "workers-ai-provider": "^2.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@openai/agents": "^0.3.0",
    "@playwright/test": "^1.56.1",
    "@types/franc": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^20.0.0",
    "bun-types": "^1.3.13",
    "esbuild": "^0.27.0",
    "js-yaml": "^4.1.0",
    "jscodeshift": "^17.3.0",
    "playwright": "^1.56.1",
    "ws": "^8.18.3"
  }
}
