{
  "name": "sndbrd-demo",
  "version": "1.0.0",
  "description": "Voice Agent Demo using OpenAI Agents SDK with sndbrd",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:frontend\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
